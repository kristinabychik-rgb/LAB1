#include <iostream>
#include <vector>
using namespace std;
int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);
    int t;
    cin >> t;
    while (t--) {
        int n;
        cin >> n;
        vector<int> a(n);
        for (int i = 0; i < n; ++i) {
            cin >> a[i];
        }
        bool found = false;
        for (int i = 0; i < n && !found; ++i) {
            int x = a[i];
            for (int j = i + 1; j < n; ++j) {
                int y = a[j];
                if ((y % x) % 2 == 0) {
                    cout << x << " " << y << "\n";
                    found = true;
                    break;
                }
            }
        }

        if (!found) {
            cout << "-1\n";
        }
    }

    return 0;
}
